rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Resume uploads — owner can read/write their own files
    match /resumes/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // User assets (profile picture, elevator pitch videos)
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else — deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
