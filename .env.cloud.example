# ── Copy this file to .env.cloud and fill in your values ─────────────────────
# .env.cloud is git-ignored — never commit it.

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── AI (Google AI Studio → https://aistudio.google.com/app/apikey) ───────────
GEMINI_API_KEY=your-gemini-api-key

# ── Firebase client config (Firebase Console → Project Settings → Your apps) ─
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
