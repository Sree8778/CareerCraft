rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — owner can read/write their own doc (profile pic, elevator pitch URL, etc.)
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Resumes — owner can read/write (savedVersions, uploadedFiles, resumeData, defaultSmartApplyResumeId)
    match /resumes/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Resume drafts — owner can read/write (auto-save)
    match /resumeDrafts/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // API keys wallet — read-only for owner (backend Admin SDK handles writes)
    match /apiKeysWallet/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Jobs — any authenticated user can read; only backend writes
    match /jobs/{jobId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Scraped jobs pool — any authenticated user can read; only backend writes
    match /scraped_jobs/{jobId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Applications — any authenticated user can read; only backend writes
    match /applications/{appId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Interviews — candidate creates and updates their own sessions
    match /interviews/{interviewId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Messages — participants can read; only backend writes
    match /messages/{msgId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Conversations / chats — participants can read and write (messaging)
    match /conversations/{convId} {
      allow read, write: if request.auth != null;
    }
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Apply sessions — backend Admin SDK only (no client access)
    match /apply_sessions/{userId} {
      allow read, write: if false;
    }

    // Connections — participants can read their own edges; backend writes.
    // (Was missing entirely: the deny-all default silently blocked every
    // client listener, so connection counts always showed zero.)
    match /connections/{connId} {
      allow read: if request.auth != null &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow write: if false;
    }

    // Notifications — recipient can read and mark-as-read; backend creates.
    // (Also missing: the navbar bell listener was silently denied on every page.)
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
        (resource.data.candidateId == request.auth.uid || resource.data.recruiterId == request.auth.uid);
      allow update: if request.auth != null &&
        (resource.data.candidateId == request.auth.uid || resource.data.recruiterId == request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // Everything else — deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
